# FakeScope Backend — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ── Gemini (P2 - Backend Core) ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key_here

# ── SightEngine (P3 - Image/Deepfake) ─────────────────────────────────────────
SIGHTENGINE_API_USER=your_sightengine_user_here
SIGHTENGINE_API_SECRET=your_sightengine_secret_here
